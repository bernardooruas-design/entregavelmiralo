# =============================================
# MiraloAI — Variáveis de ambiente
# =============================================

# Chave da RapidAPI
# Assinar: https://rapidapi.com/3205/api/instagram120 (plano BASIC = 1.000 req/mês grátis)
# Copiar a chave em: RapidAPI → Apps → default-application → Authorization → x-rapidapi-key
RAPIDAPI_KEY=cole_sua_chave_aqui

# Token do IPinfo (para detectar cidade do usuário)
# Criar conta gratuita em: https://ipinfo.io/signup (50k req/mês grátis)
IPINFO_TOKEN=cole_seu_token_aqui

PORT=3001
